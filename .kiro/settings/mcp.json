{
  "mcpServers": {
    "awslabs.aws-documentation-mcp-server": {
      "command": "uvx",
      "args": ["awslabs.aws-documentation-mcp-server@latest"],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR",
        "AWS_DOCUMENTATION_PARTITION": "aws"
      },
      "disabled": false,
      "autoApprove": ["search_documentation", "read_documentation", "read_sections"]
    },
    "awslabs.bedrock-kb-retrieval-mcp-server": {
      "command": "uvx",
      "args": ["awslabs.bedrock-kb-retrieval-mcp-server@latest"],
      "env": {
        "AWS_PROFILE": "default",
        "AWS_REGION": "us-east-1",
        "FASTMCP_LOG_LEVEL": "ERROR",
        "BEDROCK_KB_RERANKING_ENABLED": "false"
      },
      "disabled": false
    },
    "bedrock-agentcore-mcp-server": {
      "command": "uvx",
      "args": ["awslabs.amazon-bedrock-agentcore-mcp-server@latest"],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "disabled": false,
      "autoApprove": ["search_agentcore_docs", "fetch_agentcore_doc"]
    },
    "awslabs.sagemaker-ai-mcp-server": {
      "command": "uvx",
      "args": ["awslabs.sagemaker-ai-mcp-server@latest", "--allow-write", "--allow-sensitive-data-access"],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "disabled": false
    },
    "awslabs.dynamodb-mcp-server": {
      "command": "uvx",
      "args": ["awslabs.dynamodb-mcp-server@latest"],
      "env": {
        "DDB-MCP-READONLY": "true",
        "AWS_PROFILE": "default",
        "AWS_REGION": "us-west-2",
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "disabled": false
    },
    "awslabs.s3-tables-mcp-server": {
      "command": "uvx",
      "args": ["awslabs.s3-tables-mcp-server@latest"],
      "env": {
        "AWS_PROFILE": "default",
        "AWS_REGION": "us-east-1"
      },
      "disabled": false
    },
    "awslabs.aws-healthomics-mcp-server": {
      "command": "uvx",
      "args": ["awslabs.aws-healthomics-mcp-server@latest"],
      "env": {
        "AWS_REGION": "us-east-1",
        "AWS_PROFILE": "default",
        "FASTMCP_LOG_LEVEL": "WARNING"
      },
      "disabled": false,
      "disabledTools": [
        "ListAHOWorkflows", "CreateAHOWorkflow", "GetAHOWorkflow", "CreateAHOWorkflowVersion",
        "ListAHOWorkflowVersions", "StartAHORun", "ListAHORuns", "GetAHORun", "ListAHORunTasks",
        "GetAHORunTask", "GetAHORunLogs", "GetAHORunManifestLogs", "GetAHORunEngineLogs",
        "GetAHOTaskLogs", "AnalyzeAHORunPerformance", "GenerateAHORunTimeline", "DiagnoseAHORunFailure",
        "LintAHOWorkflowDefinition", "LintAHOWorkflowBundle", "SearchGenomicsFiles",
        "GetSupportedFileTypes", "PackageAHOWorkflow", "GetAHOSupportedRegions", "ListCodeConnections",
        "CreateCodeConnection", "GetCodeConnection", "ListECRRepositories", "CheckContainerAvailability",
        "CloneContainerToECR", "GrantHealthOmicsRepositoryAccess", "ListPullThroughCacheRules",
        "CreatePullThroughCacheForHealthOmics", "CreateContainerRegistryMap", "ValidateHealthOmicsECRConfig"
      ]
    },
    "awslabs.healthlake-mcp-server": {
      "command": "uvx",
      "args": ["awslabs.healthlake-mcp-server@latest"],
      "env": {
        "AWS_REGION": "us-east-1",
        "AWS_PROFILE": "default",
        "MCP_LOG_LEVEL": "WARNING"
      },
      "disabled": false,
      "disabledTools": [
        "list_datastores", "get_datastore_details", "create_fhir_resource", "read_fhir_resource",
        "update_fhir_resource", "delete_fhir_resource", "search_fhir_resources", "patient_everything",
        "start_fhir_import_job", "start_fhir_export_job", "list_fhir_jobs"
      ]
    }
  }
}
